---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const title = "Before & After Gallery | Route95";
const description = "See real results from Route95 Mobile Car Detailing in Fort Lauderdale. Before and after photos of exterior wash, interior detail, and full packages.";

const galleryItems = [
  {
    service: "Hand Wash",
    vehicle: "Toyota RAV4",
    pairs: [
      { before: "/gallery/hand-wash-before-1.jpeg", after: "/gallery/hand-wash-after-1.jpeg" },
      { before: "/gallery/hand-wash-before-2.jpeg", after: "/gallery/hand-wash-after-2.jpeg" },
    ]
  },
  {
    service: "Wheel Cleaning",
    vehicle: "Porsche Cayenne",
    pairs: [
      { before: "/gallery/wheel-cleaning-before-1.jpeg", after: "/gallery/wheel-cleaning-after-1.jpeg" },
      { before: "/gallery/wheel-cleaning-before-2.jpeg", after: "/gallery/wheel-cleaning-after-2.jpeg" },
    ]
  },
  {
    service: "Seat Shampooing",
    vehicle: "SUV",
    pairs: [
      { before: "/gallery/seat-shampooing-before-1.jpeg", after: "/gallery/seat-shampooing-after-1.jpeg" },
      { before: "/gallery/seat-shampooing-before-2.jpeg", after: "/gallery/seat-shampooing-after-2.jpeg" },
    ]
  },
  {
    service: "Trim Restoration",
    vehicle: "Toyota RAV4",
    pairs: [
      { before: "/gallery/trim-restoration-before-1.jpeg", after: "/gallery/trim-restoration-after-1.jpeg" },
    ]
  },
];
---

<BaseLayout title={title} description={description} currentPage="/gallery/">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-[#0c2448] to-[#1a5ca0] text-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="text-4xl lg:text-5xl font-bold mb-6">Before & After Car Detailing Gallery</h1>
      <p class="text-xl text-gray-200 max-w-3xl mb-8">
        Real results from real vehicles in Fort Lauderdale, Pompano Beach, Dania Beach, and Hollywood. Every photo shows actual work performed by Route95 Mobile Car Detailing — no filters, no digital enhancement.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={`${base}contact/`} class="bg-[#4da3ff] text-white px-6 py-3 rounded-md font-semibold hover:bg-[#3d8fe0] transition-colors text-lg text-center">
          Book Your Detail
        </a>
        <a href="tel:+17542152272" class="btn-accent text-lg flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call 754-215-2272
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-[#0f2a4a] mb-8">What Does Professional Mobile Detailing Look Like?</h2>
      <p class="text-gray-600 mb-8 max-w-3xl">
        Every vehicle we detail in South Florida faces the same enemies: UV radiation, salt air, humidity, and hard water. These before-and-after results show what professional mobile detailing can do — from basic hand washes to full paint correction and interior restoration.
      </p>

      <div class="space-y-12">
        {galleryItems.map((item) => (
          <div>
            <h3 class="text-xl font-bold text-[#0f2a4a] mb-2">{item.service}</h3>
            <p class="text-gray-600 text-sm mb-4">{item.vehicle}</p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {item.pairs.map((pair, i) => (
                <div class="bg-gray-50 rounded-xl overflow-hidden">
                  <div class="grid grid-cols-2 gap-1">
                    <div class="relative">
                      <img src={pair.before} alt={`Before — ${item.service} on ${item.vehicle}`} class="w-full h-48 object-cover" loading="lazy" />
                      <span class="absolute top-2 left-2 bg-black/60 text-white text-xs font-semibold px-2 py-1 rounded">Before</span>
                    </div>
                    <div class="relative">
                      <img src={pair.after} alt={`After — ${item.service} on ${item.vehicle}`} class="w-full h-48 object-cover" loading="lazy" />
                      <span class="absolute top-2 left-2 bg-[#0f2a4a]/80 text-white text-xs font-semibold px-2 py-1 rounded">After</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 bg-gray-50 rounded-xl p-8 text-center">
        <h3 class="text-xl font-bold text-[#0f2a4a] mb-4">More Categories Coming Soon</h3>
        <p class="text-gray-600 max-w-2xl mx-auto">
          We are adding more before-and-after photos as we detail vehicles across Broward County. Check back for new categories including interior deep cleaning, odor removal, and full exterior detail.
        </p>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-12 lg:py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-[#0f2a4a] mb-8">Where Do We Detail?</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href={`${base}`} class="bg-white rounded-lg p-4 text-center hover:shadow-md transition-shadow">
          <span class="font-semibold text-[#0f2a4a]">Fort Lauderdale</span>
        </a>
        <a href={`${base}mobile-car-detailing-pompano-beach/`} class="bg-white rounded-lg p-4 text-center hover:shadow-md transition-shadow">
          <span class="font-semibold text-[#0f2a4a]">Pompano Beach</span>
        </a>
        <a href={`${base}mobile-car-detailing-dania-beach/`} class="bg-white rounded-lg p-4 text-center hover:shadow-md transition-shadow">
          <span class="font-semibold text-[#0f2a4a]">Dania Beach</span>
        </a>
        <a href={`${base}mobile-car-detailing-hollywood-fl/`} class="bg-white rounded-lg p-4 text-center hover:shadow-md transition-shadow">
          <span class="font-semibold text-[#0f2a4a]">Hollywood, FL</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 lg:py-16 bg-gradient-to-br from-[#0c2448] to-[#1a5ca0] text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to See These Results on Your Vehicle?</h2>
      <p class="text-xl text-gray-200 mb-8">
        Route95 Mobile Car Detailing comes to your location in Fort Lauderdale, Pompano Beach, Dania Beach, and Hollywood. Same-day appointments available.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}mobile-car-detailing-prices-fort-lauderdale/`} class="bg-[#4da3ff] text-white px-6 py-3 rounded-md font-semibold hover:bg-[#3d8fe0] transition-colors text-lg text-center">
          See Pricing
        </a>
        <a href="tel:+17542152272" class="btn-accent text-lg flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call 754-215-2272
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
