---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const title = "Galeria Antes y Despues | Route95";
const description = "Vea resultados reales del detallado movil de Route95 en Fort Lauderdale. Fotos de antes y despues de lavado exterior, detallado interior y paquetes completos.";

const galleryItems = [
  { service: "Limpieza Completa", vehicle: "Sedan", category: "Detallado Completo" },
  { service: "Detallado Interior", vehicle: "SUV", category: "Interior" },
  { service: "Lavado a Mano y Encerado", vehicle: "Camioneta", category: "Exterior" },
  { service: "Limpieza de Cuero", vehicle: "Sedan", category: "Interior" },
  { service: "Renovacion Premium", vehicle: "SUV", category: "Detallado Completo" },
  { service: "Eliminacion de Olores", vehicle: "Sedan", category: "Interior" },
];
---

<BaseLayout title={title} description={description} currentPage="/es/galeria/">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-[#0c2448] to-[#1a5ca0] text-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="text-4xl lg:text-5xl font-bold mb-6">Galeria de Detallado Antes y Despues</h1>
      <p class="text-xl text-gray-200 max-w-3xl mb-8">
        Resultados reales de vehiculos reales en Fort Lauderdale, Pompano Beach, Dania Beach y Hollywood. Cada foto muestra trabajo real realizado por Route95 Mobile Car Detailing — sin filtros, sin mejoras digitales.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={`${base}es/contacto/`} class="bg-[#4da3ff] text-white px-6 py-3 rounded-md font-semibold hover:bg-[#3d8fe0] transition-colors text-lg text-center">
          Reserve Su Detallado
        </a>
        <a href="tel:+17542152272" class="btn-accent text-lg flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Llame al 754-215-2272
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-[#0f2a4a] mb-8">¿Como Luce el Detallado Movil Profesional?</h2>
      <p class="text-gray-600 mb-8 max-w-3xl">
        Cada vehiculo que detallamos en el sur de Florida enfrenta los mismos enemigos: radiacion UV, aire salado, humedad y agua dura. Estos resultados de antes y despues muestran lo que el detallado movil profesional puede lograr — desde lavados basicos hasta correccion de pintura y restauracion interior completa.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {galleryItems.map((item) => (
          <div class="bg-gray-50 rounded-xl overflow-hidden">
            <div class="grid grid-cols-2 gap-1">
              <div class="bg-[#0f2a4a] h-48 flex items-center justify-center">
                <div class="text-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto text-gray-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span class="text-gray-400 text-sm font-semibold">Antes</span>
                </div>
              </div>
              <div class="bg-[#1a3a5c] h-48 flex items-center justify-center">
                <div class="text-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto text-gray-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span class="text-gray-400 text-sm font-semibold">Despues</span>
                </div>
              </div>
            </div>
            <div class="p-4">
              <h3 class="font-bold text-[#0f2a4a]">{item.service}</h3>
              <p class="text-gray-600 text-sm">{item.vehicle} — {item.category}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 bg-gray-50 rounded-xl p-8 text-center">
        <h3 class="text-xl font-bold text-[#0f2a4a] mb-4">Fotos Proximamente</h3>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Estamos construyendo nuestra galeria con fotos reales de antes y despues de vehiculos detallados en todo el Condado de Broward. Cada imagen mostrara trabajo real de Route95 — sin fotos de stock, sin mejoras digitales.
        </p>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-12 lg:py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-[#0f2a4a] mb-8">¿Donde Detallamos?</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href={`${base}es/`} class="bg-white rounded-lg p-4 text-center hover:shadow-md transition-shadow">
          <span class="font-semibold text-[#0f2a4a]">Fort Lauderdale</span>
        </a>
        <a href={`${base}es/detallado-movil-pompano-beach/`} class="bg-white rounded-lg p-4 text-center hover:shadow-md transition-shadow">
          <span class="font-semibold text-[#0f2a4a]">Pompano Beach</span>
        </a>
        <a href={`${base}es/detallado-movil-dania-beach/`} class="bg-white rounded-lg p-4 text-center hover:shadow-md transition-shadow">
          <span class="font-semibold text-[#0f2a4a]">Dania Beach</span>
        </a>
        <a href={`${base}es/detallado-movil-hollywood-fl/`} class="bg-white rounded-lg p-4 text-center hover:shadow-md transition-shadow">
          <span class="font-semibold text-[#0f2a4a]">Hollywood, FL</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 lg:py-16 bg-gradient-to-br from-[#0c2448] to-[#1a5ca0] text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">¿Listo para Ver Estos Resultados en Su Vehiculo?</h2>
      <p class="text-xl text-gray-200 mb-8">
        Route95 Mobile Car Detailing va a su ubicacion en Fort Lauderdale, Pompano Beach, Dania Beach y Hollywood. Citas el mismo dia disponibles.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}es/precios-detallado-movil-fort-lauderdale/`} class="bg-[#4da3ff] text-white px-6 py-3 rounded-md font-semibold hover:bg-[#3d8fe0] transition-colors text-lg text-center">
          Ver Precios
        </a>
        <a href="tel:+17542152272" class="btn-accent text-lg flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Llame al 754-215-2272
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
