        </p>
      </div>

    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-12 lg:py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-[#0f2a4a] mb-8">Nuestros Servicios de Limpieza de Tapicería</h2>
