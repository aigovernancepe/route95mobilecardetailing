      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Limpieza de Cuero", "url": `${siteUrl}/es/limpieza-de-cuero-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Acondicionamiento de Cuero", "url": `${siteUrl}/es/acondicionamiento-de-cuero-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Limpieza a Vapor", "url": `${siteUrl}/es/limpieza-a-vapor-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Eliminación de Olores", "url": `${siteUrl}/es/eliminacion-de-olores-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Eliminación de Olor a Humo", "url": `${siteUrl}/es/eliminacion-de-olor-a-humo-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Eliminación de Pelo de Mascota", "url": `${siteUrl}/es/eliminacion-de-pelo-de-mascota-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Aspirado Interior", "url": `${siteUrl}/es/aspirado-interior-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Protección de Tela", "url": `${siteUrl}/es/proteccion-de-tela-fort-lauderdale/` }}
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué Incluye la Limpieza de Tapicería de Autos?",
