        <!-- Fabric Protection -->
        <div>
          <h3 class="text-xl font-bold text-[#0f2a4a] mb-2">Protección de Tela</h3>
          <p class="text-gray-600 mb-2">
            Recubrimiento profesional de protección de tela que repele líquidos, previene manchas y hace que la limpieza de derrames futuros sea sin esfuerzo. Se aplica después de la limpieza de tapicería para mantener tus asientos de tela y alfombras protegidos entre detallados.
          </p>
          <a href={localizedUrl('es', 'fabric-protection-fort-lauderdale')} class="text-[#0f2a4a] font-medium hover:text-[#c0c7cf] transition-colors">
            Más información sobre Protección de Tela Fort Lauderdale →
