---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import { localizedUrl } from '../../i18n/utils';

const url = (slug: string) => localizedUrl('es', slug);
const title = "Lavado Rápido Fort Lauderdale | Route95";
const description = "Lavado Rápido móvil en Fort Lauderdale. Lavado exterior a mano, llantas, acondicionador y ventanas. Desde $40. Llame al 754-215-2272.";

const parentCategory = {
  href: url('car-detailing-services-fort-lauderdale'),
  title: "Servicios de Detallado"
};

const siteUrl = "https://route95mobilecardetailing.com";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${siteUrl}/es/lavado-rapido-fort-lauderdale/#service`,
  "name": "Lavado Rápido Fort Lauderdale",
  "description": description,
  "url": `${siteUrl}/es/lavado-rapido-fort-lauderdale/`,
  "serviceType": "Mobile Car Detailing",
  "provider": { "@id": `${siteUrl}/#business` },
  "areaServed": [
    { "@type": "City", "name": "Fort Lauderdale" },
    { "@type": "City", "name": "Dania Beach" },
    { "@type": "City", "name": "Hollywood" },
    { "@type": "City", "name": "Pompano Beach" }
  ],
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "USD",
    "lowPrice": 40,
    "highPrice": 60,
    "offerCount": 3
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Cuanto Cuesta un Lavado Rapido?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los precios del Lavado Rapido comienzan en $40 para sedanes, $50 para SUVs y crossovers, y $60 para camionetas y vehiculos grandes."
      }
    },
    {
      "@type": "Question",
      "name": "Que Incluye el Lavado Rapido?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El Lavado Rapido incluye lavado exterior a mano, limpieza de llantas y rines, acondicionador de llantas, y limpieza de ventanas exteriores."
      }
    },
    {
      "@type": "Question",
      "name": "Cuanto Tiempo Toma un Lavado Rapido?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Un Lavado Rapido tipicamente toma de 20 a 30 minutos dependiendo del tamano y condicion del vehiculo."
      }
    }
  ]
};

const schemas = [serviceSchema, faqSchema];
---

<ServiceLayout
  title={title}
  description={description}
  h1="Lavado Rapido Fort Lauderdale"
  intro="Un lavado exterior rapido para mantener su auto impecable entre detallados completos. Vamos a su ubicacion con todo lo necesario."
  currentPage="/es/lavado-rapido-fort-lauderdale/"
  parentCategory={parentCategory}
  schema={schemas}
>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-8">
      <section>
        <p class="text-gray-600 mb-4">
          El Lavado Rapido es nuestro paquete exterior de nivel basico disenado para conductores de Fort Lauderdale que desean mantener un vehiculo limpio sin el compromiso de tiempo de un detallado completo. Cubre lo esencial del exterior: un lavado a mano completo, limpieza de llantas y rines, acondicionador de llantas, y limpieza de ventanas exteriores.
        </p>
        <p class="text-gray-600 mb-4">
          Perfecto para mantenimiento semanal o quincenal, el Lavado Rapido mantiene el exterior de su auto presentable y protegido del sol del sur de Florida, el aire salado y la suciedad diaria. Usamos productos premium Chemical Guys y el metodo de dos cubetas para garantizar un acabado sin rayaduras cada vez.
        </p>
        <p class="text-gray-600">
          Servimos Fort Lauderdale, Dania Beach, Hollywood y Pompano Beach incluyendo Las Olas, Nurmi Isles y Seven Isles. Citas el mismo dia frecuentemente disponibles.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-[#0f2a4a] mb-4">Cuanto Cuesta un Lavado Rapido?</h2>
        <p class="text-gray-600 mb-4">
          <strong>Los precios del Lavado Rapido comienzan en $40 para sedanes, $50 para SUVs y crossovers, y $60 para camionetas y vehiculos grandes.</strong>
        </p>
        <p class="text-gray-600">
          El precio varia segun el tamano del vehiculo debido al area de superficie adicional y el tiempo requerido. Proporcionamos precios exactos basados en su vehiculo especifico cuando nos llame o envie un mensaje.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-[#0f2a4a] mb-4">Que Incluye el Lavado Rapido?</h2>
        <ul class="list-disc list-inside text-gray-600 mb-4 space-y-2">
          <li><strong>Lavado a Mano</strong> — Lavado exterior completo usando el metodo de dos cubetas y jabon de pH balanceado</li>
          <li><strong>Llantas y Rines</strong> — Polvo de frenos y suciedad del camino removidos de rines y llantas</li>
          <li><strong>Acondicionador de Llantas</strong> — Llantas acondicionadas para un acabado limpio y oscuro</li>
          <li><strong>Limpieza de Ventanas</strong> — Vidrios exteriores limpiados sin rayas</li>
        </ul>
        <p class="text-gray-600">
          Necesita limpieza interior tambien? Consulte nuestro paquete <a href={url('fresh-start-fort-lauderdale')} class="text-[#1a5ca0] underline hover:text-[#0f2a4a]">Nuevo Comienzo</a>, o agregue servicios individuales como acondicionador de llantas, eliminacion de pelo de mascota o limpieza de tapetes a cualquier paquete.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-[#0f2a4a] mb-4">Cuanto Tiempo Toma un Lavado Rapido?</h2>
        <p class="text-gray-600 mb-4">
          <strong>Un Lavado Rapido tipicamente toma de 20 a 30 minutos dependiendo del tamano y condicion del vehiculo.</strong>
        </p>
        <p class="text-gray-600">
          Como es un servicio solo exterior, es nuestro servicio mas rapido. Muchos de nuestros clientes en Fort Lauderdale nos reservan en su oficina y regresan a un auto recien lavado.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-[#0f2a4a] mb-6">Nuestro Proceso de Lavado Rapido</h2>
        <ProcessSteps steps={[
          { title: "Pre-Enjuague", description: "Enjuagamos su vehiculo a fondo para remover suciedad suelta, arena y escombros antes de cualquier lavado de contacto." },
          { title: "Lavado a Mano con Dos Cubetas", description: "Lavado exterior completo con jabon Chemical Guys de pH balanceado usando guantes de microfibra limpios." },
          { title: "Llantas y Rines", description: "Rines y llantas se limpian con cepillos dedicados y limpiadores seguros para rines." },
          { title: "Limpieza de Ventanas", description: "Todos los vidrios exteriores limpiados sin rayas para un acabado cristalino." },
          { title: "Secado e Inspeccion", description: "Secado a mano con toallas de microfibra limpias. Inspeccion final para asegurar que cada superficie exterior este impecable." }
        ]} />
      </section>
    </div>

    <aside class="lg:col-span-1">
      <div class="sticky top-24 space-y-6">
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="font-bold text-[#0f2a4a] mb-4">Precios del Lavado Rapido</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-2">
              <span class="text-[#c0c7cf] font-bold">$</span>
              <span class="text-gray-600">Sedan / Hatchback: <strong>$40</strong></span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#c0c7cf] font-bold">$</span>
              <span class="text-gray-600">Crossover / SUV: <strong>$50</strong></span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#c0c7cf] font-bold">$</span>
              <span class="text-gray-600">Camioneta / Grande: <strong>$60</strong></span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#c0c7cf] mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-gray-600">20-30 minutos</span>
            </li>
          </ul>
        </div>

        <div class="bg-[#0f2a4a] rounded-xl p-6 text-white">
          <h3 class="font-bold mb-4">Reserve Su Lavado Rapido</h3>
          <p class="text-gray-200 text-sm mb-4">
            Citas el mismo dia disponibles en todo Fort Lauderdale.
          </p>
          <a href="/es/contacto/" class="w-full flex items-center justify-center gap-2 bg-[#4da3ff] text-white px-4 py-3 rounded-md font-semibold hover:bg-[#3d8fe0] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Reservar Ahora
          </a>
        </div>

        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="font-bold text-[#0f2a4a] mb-4">Otros Paquetes</h3>
          <ul class="space-y-2">
            <li><a href={url('fresh-start-fort-lauderdale')} class="text-gray-600 hover:text-[#c0c7cf]">Nuevo Comienzo</a></li>
            <li><a href={url('complete-clean-fort-lauderdale')} class="text-gray-600 hover:text-[#c0c7cf]">Limpieza Completa</a></li>
            <li><a href={url('premium-refresh-fort-lauderdale')} class="text-gray-600 hover:text-[#c0c7cf]">Renovacion Premium</a></li>
            <li><a href={url('car-detailing-services-fort-lauderdale')} class="text-[#0f2a4a] font-semibold hover:text-[#c0c7cf]">Ver Todos los Paquetes</a></li>
          </ul>
        </div>
      </div>
    </aside>
  </div>
</ServiceLayout>
