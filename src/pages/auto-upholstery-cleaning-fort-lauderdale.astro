---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

// WhatsApp configuration
const whatsappNumber = "17542152272";
const whatsappMessage = "Hi! I'd like to get a quote for mobile car detailing.";
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;

const title = "Auto Upholstery Cleaning Fort Lauderdale | Route95";
const description = "Mobile auto upholstery cleaning in Fort Lauderdale. Fabric seats, leather, carpets deep cleaned on-site. Same-day available. Call 754-215-2272.";

const siteUrl = "https://route95mobilecardetailing.com";
const categorySchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${siteUrl}/auto-upholstery-cleaning-fort-lauderdale/#service`,
  "name": "Mobile Auto Upholstery Cleaning Fort Lauderdale",
  "description": description,
  "url": `${siteUrl}/auto-upholstery-cleaning-fort-lauderdale/`,
  "serviceType": "Mobile Auto Upholstery Cleaning",
  "provider": { "@id": `${siteUrl}/#business` },
  "areaServed": [
    { "@type": "City", "name": "Fort Lauderdale" },
    { "@type": "City", "name": "Dania Beach" },
    { "@type": "City", "name": "Hollywood" },
    { "@type": "City", "name": "Pompano Beach" }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Auto Upholstery Cleaning Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Seat Shampooing", "url": `${siteUrl}/seat-shampooing-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Carpet Shampooing", "url": `${siteUrl}/carpet-shampooing-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Leather Cleaning", "url": `${siteUrl}/leather-cleaning-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Leather Conditioning", "url": `${siteUrl}/leather-conditioning-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Steam Cleaning", "url": `${siteUrl}/steam-cleaning-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Odor Removal", "url": `${siteUrl}/odor-removal-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Smoke Odor Removal", "url": `${siteUrl}/smoke-odor-removal-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pet Hair Removal", "url": `${siteUrl}/pet-hair-removal-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Interior Vacuuming", "url": `${siteUrl}/interior-vacuuming-fort-lauderdale/` }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fabric Protection", "url": `${siteUrl}/fabric-protection-fort-lauderdale/` }}
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What Does Auto Upholstery Cleaning Include?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Auto upholstery cleaning includes deep extraction of fabric seats, carpet shampooing, leather cleaning, and stain removal from all soft surfaces inside your vehicle. In Fort Lauderdale, we also treat for mildew and moisture trapped in upholstery fibers by Florida's year-round humidity."
      }
    },
    {
      "@type": "Question",
      "name": "How Much Does Vehicle Upholstery Cleaning Cost in Fort Lauderdale?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Vehicle upholstery cleaning in Fort Lauderdale ranges from $75 to $200 depending on the number of surfaces and their condition. A basic seat and carpet shampoo starts around $75. Full upholstery cleaning with leather care, stain treatment, and fabric protection runs $150-$200. Heavily stained or neglected upholstery may cost more."
      }
    },
    {
      "@type": "Question",
      "name": "How Often Should You Clean Car Upholstery in Florida?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In Florida's humid climate, car upholstery should be professionally cleaned every 3-4 months to prevent mildew, bacteria growth, and permanent staining. Vehicles with pets, children, or daily commuters may need cleaning every 2-3 months. Regular upholstery cleaning also preserves resale value by preventing fabric and leather deterioration."
      }
    },
    {
      "@type": "Question",
      "name": "Can You Remove Stains from Car Upholstery?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, most car upholstery stains can be removed with professional extraction equipment and the right cleaning agents. We use oxygen-infused shampoos for fabric, pH-balanced cleaners for leather, and enzymatic treatments for organic stains like food and sweat. The sooner stains are treated, the higher the success rate."
      }
    },
    {
      "@type": "Question",
      "name": "Is Mobile Auto Upholstery Cleaning as Effective as Shop Service?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mobile auto upholstery cleaning delivers the same results as shop service because we bring professional-grade hot water extractors, steam cleaners, and Chemical Guys products directly to your location. The equipment and technique are identical — the only difference is we come to you in Fort Lauderdale, saving you the trip and wait time."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Interior Car Detailing",
      "item": `${siteUrl}/interior-car-detailing-fort-lauderdale/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Auto Upholstery Cleaning",
      "item": `${siteUrl}/auto-upholstery-cleaning-fort-lauderdale/`
    }
  ]
};
---

<BaseLayout title={title} description={description} currentPage="/auto-upholstery-cleaning-fort-lauderdale/" schema={[categorySchema, faqSchema, breadcrumbSchema]}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-[#0c2448] to-[#1a5ca0] text-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="text-4xl lg:text-5xl font-bold mb-6">Auto Upholstery Cleaning in Fort Lauderdale — Route95 Mobile Car Detailing</h1>
      <p class="text-xl text-gray-200 max-w-3xl mb-6">
        <strong>Mobile auto upholstery cleaning that comes to your Fort Lauderdale location. We deep clean fabric seats, leather, carpets, and remove stains and odors on-site using professional extraction equipment.</strong>
      </p>
      <p class="text-lg text-gray-200 max-w-3xl mb-4">
        Florida's humidity, sand, and sun break down vehicle upholstery faster than anywhere else. Sweat soaks into fabric seats, leather dries and cracks, and mildew grows in damp carpet fibers. We bring professional upholstery cleaning directly to your home or office in Fort Lauderdale, Dania Beach, Hollywood, and Pompano Beach.
      </p>
      <p class="text-lg text-gray-200 max-w-3xl mb-4">
