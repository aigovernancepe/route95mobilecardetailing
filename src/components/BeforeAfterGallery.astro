---
interface ImagePair {
  before: string;
  after: string;
  alt: string;
}

interface Props {
  title: string;
  description: string;
  pairs: ImagePair[];
  galleryLink?: string;
  galleryLinkText?: string;
}

const { title, description, pairs, galleryLink, galleryLinkText } = Astro.props;
---

<section class="not-prose mt-12 pt-8 border-t border-gray-200">
  <h2 class="text-2xl font-bold text-[#0f2a4a] mb-3">{title}</h2>
  <p class="text-gray-600 mb-6">{description}</p>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {pairs.map((pair) => (
      <div class="bg-gray-50 rounded-xl overflow-hidden">
        <div class="grid grid-cols-2 gap-1">
          <div class="relative">
            <img src={pair.before} alt={pair.alt} class="w-full h-48 object-cover" loading="lazy" />
            <span class="absolute top-2 left-2 bg-black/60 text-white text-xs font-semibold px-2 py-1 rounded">Before</span>
          </div>
          <div class="relative">
            <img src={pair.after} alt={pair.alt} class="w-full h-48 object-cover" loading="lazy" />
            <span class="absolute top-2 left-2 bg-[#0f2a4a]/80 text-white text-xs font-semibold px-2 py-1 rounded">After</span>
          </div>
        </div>
        <p class="px-4 py-3 text-sm text-gray-600 font-medium">{pair.alt}</p>
      </div>
    ))}
  </div>
  {galleryLink && (
    <p class="mt-6 text-center">
      <a href={galleryLink} class="text-[#0f2a4a] font-semibold hover:text-[#c0c7cf] transition-colors inline-flex items-center gap-2">
        {galleryLinkText || "See more results"}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </p>
  )}
</section>
