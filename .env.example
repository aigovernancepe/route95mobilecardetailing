# Google Search Console Configuration
# ──────────────────────────────────────
# Your site's verified property URL in GSC.
# Format: "https://example.com/" or "sc-domain:example.com"
GSC_PROPERTY=https://route95mobilecardetailing.com/

# Path to the downloaded service-account JSON key file.
# Used locally for development/testing. In production, credentials
# are loaded from Google Secret Manager.
GOOGLE_APPLICATION_CREDENTIALS=./gsc-service-account.json

# Google Cloud project ID (for Secret Manager)
GCP_PROJECT_ID=your-gcp-project-id

# Secret Manager secret name where the GSC key JSON is stored
GSC_SECRET_NAME=gsc-service-account-key
